# Server Configuration
PORT=3001
NODE_ENV=development

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# MQTT Configuration
MQTT_PORT=1883
MQTT_WS_PORT=8080
MQTT_USERNAME=
MQTT_PASSWORD=

# WebSocket Configuration
WS_HEARTBEAT_INTERVAL=30000
WS_MAX_PAYLOAD_SIZE=1048576

# Firebase (for Push Notifications)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Main Backend API (for service-to-service communication)
BACKEND_API_URL=http://localhost:3000
BACKEND_API_SECRET=your-backend-secret-key

# Logging
LOG_LEVEL=info
